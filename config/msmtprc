# Set default values for all following accounts.
defaults
auth           on
tls            on
tls_trust_file /etc/ssl/certs/ca-bundle.crt
logfile        ~/.msmtp.log

# iCloud Account
account        icloud
host           smtp.mail.me.com
port           587
from           deine.email@icloud.com
user           deine.email@icloud.com
passwordeval   "secret-tool lookup email deine.email@icloud.com"

# Set a default account
account default : icloud
